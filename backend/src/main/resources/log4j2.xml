<?xml version="1.0" encoding="UTF-8"?>
<Configuration status="WARN" monitorInterval="30">
    <Properties>
        <!-- Do not name this LOG_DIR: same key as env lookup causes infinite interpolation. -->
        <Property name="app.log.dir">${env:LOG_DIR:-logs}</Property>
        <Property name="LOG_FILE_NAME">univoyage</Property>
        <Property name="PATTERN">%d{yyyy-MM-dd HH:mm:ss.SSS} %5p [%t] %c{1.} - %m%n%wEx</Property>
    </Properties>

    <Appenders>
        <!-- INFO+ on stdout (DEBUG stays in file only for com.univoyage) -->
        <Console name="Console" target="SYSTEM_OUT">
            <ThresholdFilter level="INFO" onMatch="ACCEPT" onMismatch="DENY"/>
            <PatternLayout pattern="${PATTERN}" charset="UTF-8"/>
        </Console>

        <RollingFile name="RollingFile"
                     fileName="${app.log.dir}/${LOG_FILE_NAME}.log"
                     filePattern="${app.log.dir}/${LOG_FILE_NAME}-%d{yyyy-MM-dd}-%i.log.gz">
            <PatternLayout pattern="${PATTERN}" charset="UTF-8"/>
            <Policies>
                <TimeBasedTriggeringPolicy interval="1" modulate="true"/>
                <SizeBasedTriggeringPolicy size="10 MB"/>
            </Policies>
            <DefaultRolloverStrategy max="14"/>
        </RollingFile>
    </Appenders>

    <Loggers>
        <!-- Application DEBUG in log file; console still INFO+ via ThresholdFilter -->
        <Logger name="com.univoyage" level="debug" additivity="false">
            <AppenderRef ref="Console"/>
            <AppenderRef ref="RollingFile"/>
        </Logger>

        <Root level="info">
            <AppenderRef ref="Console"/>
            <AppenderRef ref="RollingFile"/>
        </Root>
    </Loggers>
</Configuration>
