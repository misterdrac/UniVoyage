# Database Configuration
# PostgreSQL database connection settings
DB_HOST=localhost
DB_PORT=5432
DB_NAME=univoyage_db
DB_USERNAME=your_db_username
DB_PASSWORD=your_db_password

# JWT Configuration
# Secret key for JWT token signing (use a strong random string in production)
# Generate a secure secret: openssl rand -base64 32
JWT_SECRET=your-jwt-secret-key-change-this-in-production

# Weather API Configuration
# OpenWeather API key (get one at https://openweathermap.org/api)
# Required for weather features
OPENWEATHER_API_KEY=your-openweather-api-key

# Geoapify API Configuration
# Get your API key from https://myprojects.geoapify.com/
# Required for Points of Interest / Places features
GEOAPIFY_API_KEY=your-geoapify-api-key

# Google Gemini AI Configuration
# Get your API key from https://aistudio.google.com/apikey
# Required for AI features (itinerary generation, packing suggestions)
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-2.5-flash-lite

# Amadeus Hotel API Configuration
# Get your credentials from https://developers.amadeus.com
# Required for hotel/accommodation features
AMADEUS_API_KEY=your-amadeus-api-key
AMADEUS_API_SECRET=your-amadeus-api-secret

# Google OAuth Configuration
# Optional: Only needed if Google OAuth login is enabled
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:8080/api/auth/google/callback

