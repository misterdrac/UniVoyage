# Database Configuration
# PostgreSQL database connection settings (required for mvn spring-boot:run / IDE — no default password)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=univoyage_db
DB_USERNAME=postgres
DB_PASSWORD=your_db_password

# Docker Compose: both services load this file — required for `docker compose up`
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_db_password
# Host port for Postgres (container still uses 5432). Default 5433 avoids Windows bind errors on 5432.
# POSTGRES_HOST_PORT=5433
# Optional overrides for Spring in the backend container (defaults fall back to POSTGRES_* above)
# SPRING_DATASOURCE_USERNAME=postgres
# SPRING_DATASOURCE_PASSWORD=your_db_password
# SPRING_FLYWAY_USER=postgres
# SPRING_FLYWAY_PASSWORD=your_db_password

# JWT Configuration
# Secret key for JWT token signing (use a strong random string in production)
# Generate a secure secret: openssl rand -base64 32
JWT_SECRET=your-jwt-secret-key-change-this-in-production

# Weather API Configuration
# OpenWeather API key (get one at https://openweathermap.org/api)
# Required for weather features
OPENWEATHER_API_KEY=your-openweather-api-key

# Geoapify API Configuration
# Get your API key from https://myprojects.geoapify.com/
# Required for Points of Interest / Places features
GEOAPIFY_API_KEY=your-geoapify-api-key

# Google Gemini AI Configuration
# Get your API key from https://aistudio.google.com/apikey
# Required for AI features (itinerary generation, packing suggestions)
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-2.5-flash-lite

# Amadeus Hotel API Configuration
# Get your credentials from https://developers.amadeus.com
# Required for hotel/accommodation features
AMADEUS_API_KEY=your-amadeus-api-key
AMADEUS_API_SECRET=your-amadeus-api-secret

# Google OAuth Configuration
# Optional: Only needed if Google OAuth login is enabled
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:5173/auth/google/callback

# Currency apis
# Get credentials from https://app.exchangerate-api.com/dashboard
APP_CURRENCY_API_KEY=your-exchangerate-api-key
APP_CURRENCY_FALLBACK_KEY=your-exchangerate-fallback-api-key

# Production / staging: comma-separated frontend origins (HTTPS in production)
# CORS_ALLOWED_ORIGINS=https://your-app.example,https://www.your-app.example
