# Database Configuration
# PostgreSQL database connection settings
DB_HOST=localhost
DB_PORT=5432
DB_NAME=univoyage_db
DB_USERNAME=your_db_username
DB_PASSWORD=your_db_password

# JWT Configuration
# Secret key for JWT token signing (use a strong random string in production)
# Generate a secure secret: openssl rand -base64 32
JWT_SECRET=your-jwt-secret-key-change-this-in-production

# Weather API Configuration
# OpenWeather API key (get one at https://openweathermap.org/api)
# Optional: Weather service will throw an error if not configured
OPENWEATHER_API_KEY=your-openweather-api-key

# Google OAuth Configuration (if using Google OAuth)
# Optional: Only needed if Google OAuth login is enabled
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:8080/api/auth/google/callback

