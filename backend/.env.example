# Copy to `.env` and fill in values. Used by spring-dotenv / local runs.

# Google OAuth2
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REDIRECT_URI=http://localhost:5173/auth/google/callback

# JWT
JWT_SECRET=your_generated_jwt_secret_string
JWT_EXPIRATION=86400000

# Database (override defaults from application.yml if needed)
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=univoyage_db
# DB_USERNAME=postgres
# DB_PASSWORD=admin

# External APIs
OPENWEATHER_API_KEY=your_openweather_key
GEOAPIFY_API_KEY=your_geoapify_key
GEMINI_API_KEY=your_gemini_key

# Amadeus
AMADEUS_CLIENT_ID=your_amadeus_client_id
AMADEUS_CLIENT_SECRET=your_amadeus_client_secret

# ExchangeRate-API (trip currency / FX — pair conversion)
# https://www.exchangerate-api.com/
EXCHANGE_RATE_API_KEY=your_exchangerate_api_key
# Optional override (default: https://v6.exchangerate-api.com/v6)
# EXCHANGE_RATE_API_URL=https://v6.exchangerate-api.com/v6
